{
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Mouse Button 6 to Command+Click",
                        "manipulators": [
                            {
                                "from": { "pointing_button": "button6" },
                                "to": [
                                    {
                                        "modifiers": ["left_command"],
                                        "pointing_button": "button1"
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Mouse Button 4/5 to Hyper+H/L (AeroSpace window switching)",
                        "manipulators": [
                            {
                                "from": { "pointing_button": "button4" },
                                "to": [
                                    {
                                        "key_code": "h",
                                        "modifiers": ["left_control", "left_alt", "left_command"]
                                    }
                                ],
                                "type": "basic"
                            },
                            {
                                "from": { "pointing_button": "button5" },
                                "to": [
                                    {
                                        "key_code": "l",
                                        "modifiers": ["left_control", "left_alt", "left_command"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Mouse Button 7 to Command Key (held)",
                        "manipulators": [
                            {
                                "from": { "pointing_button": "button7" },
                                "to": [
                                    {
                                        "hold_down_milliseconds": 0,
                                        "key_code": "left_command"
                                    }
                                ],
                                "to_after_key_up": [{ "key_code": "left_command" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Caps Lock to Hyper Key (Ctrl+Alt+Cmd)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    {
                                        "key_code": "left_control",
                                        "modifiers": ["left_option", "left_command"]
                                    }
                                ],
                                "to_if_alone": [{ "key_code": "escape" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Akimbo cmd to F12 (for Leader Key app)",
                        "manipulators": [
                            {
                                "from": {
                                    "simultaneous": [
                                        { "key_code": "left_command" },
                                        { "key_code": "right_command" }
                                    ]
                                },
                                "to": [
                                    {
                                        "key_code": "f12",
                                        "modifiers": ["fn"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "mash f+j to escape",
                        "enabled": false,
                        "manipulators": [
                            {
                                "from": {
                                    "simultaneous": [
                                        { "key_code": "f" },
                                        { "key_code": "j" }
                                    ],
                                    "simultaneous_options": { "to_after_key_up": [{ "key_code": "escape" }] }
                                },
                                "to": [{ "key_code": "vk_none" }],
                                "type": "basic"
                            }
                        ]
                    }
                ]
            },
            "devices": [
                {
                    "identifiers": {
                        "is_keyboard": true,
                        "is_pointing_device": true,
                        "vendor_id": 2007
                    },
                    "ignore": false,
                    "ignore_vendor_events": true,
                    "treat_as_built_in_keyboard": true
                },
                {
                    "identifiers": {
                        "is_pointing_device": true,
                        "product_id": 45122,
                        "vendor_id": 1133
                    },
                    "ignore": false,
                    "ignore_vendor_events": true
                }
            ],
            "name": "Default",
            "virtual_hid_keyboard": {
                "country_code": 0,
                "keyboard_type_v2": "ansi"
            }
        }
